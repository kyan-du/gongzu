// 核心规律: col1 OP col2 = col3
// OP 按 MiniGrid 内上行/下行可以不同

// ── 工具函数 ──
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function randomChoice<T>(arr: readonly T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

// ── 基础类型 ──
export type EmojiContent = {
  type: 'emoji';
  emoji: string;
  rotation: 0 | 90 | 180 | 270;
  mirror: 'none' | 'horizontal' | 'vertical';
  scaled: boolean;
};
export type CellContent =
  | EmojiContent
  | { type: 'blank' }
  | { type: 'broken' };

export type MiniGrid = [CellContent, CellContent, CellContent, CellContent]; // 2×2
export type Matrix = MiniGrid[][]; // [row][col]

export type GamePhase = 'watch1' | 'answer1' | 'watch2' | 'answer2' | 'result';

// ── 行级合并规则 ──
export type SameAction = 'keep' | 'swap-lr' | 'shrink' | 'blank' | 'broken';
export type DiffAction = 'first' | 'second' | 'blank' | 'broken';

export type RowMergeRule = {
  same: SameAction;
  diff: DiffAction;
};

export type PuzzleRules = {
  topRow: RowMergeRule;
  bottomRow: RowMergeRule;
};

// ── 旧类型别名（向后兼容） ──
export type ElementTransform = string;
export type SizeTransform = string;
export type PositionTransform = string;
export type MergeStrategy = {
  sameBoth: string;
  diffBoth: string;
  blankAndNormal: string;
  brokenAndNormal: string;
  bothBlank: string;
  bothBroken: string;
  blankAndBroken: string;
};

// ── GamePuzzle ──
export interface GamePuzzle {
  matrix: Matrix;           // 阶段一矩阵 3×3
  phase1Hidden: { row: number; col: number };
  phase2Hidden: { row: number; col: number }[];
  choices: CellContent[];   // 阶段一备选池
  rules: PuzzleRules;       // 完整规律
  phase1Rules: string[];    // 阶段一可推出的规律描述
  phase2NewRules: string[]; // 阶段二新发现的规律描述
  phase2Matrix: Matrix;     // 阶段二矩阵 3×3
  phase2Choices: CellContent[];
}

